}

model municipios {
  id           Int           @id @default(autoincrement())
  codigo       String        @db.Char(50)
  nombre       String        @db.VarChar(100)
  area_km2     Decimal?      @default(0) @db.Decimal(10, 2)
  estado_id    Int
  carac_statal carac_statal?
  estados      estados       @relation(fields: [estado_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parroquias   parroquias[]

  @@unique([estado_id, codigo], map: "uq_municipio_codigo")
}

model notificaciones {
  id                Int       @id @default(autoincrement())
  usuario_global_id Int
  mensaje           String
  tipo              String?   @default("INFO") @db.VarChar(50)
  leido             Boolean?  @default(false)
  created_at        DateTime? @default(now()) @db.Timestamp(6)
}

model oficinas {
  id                   Int                   @id @default(autoincrement())
  nombre               String                @unique @db.VarChar(150)
  ubicacion_gms        String?               @db.VarChar(255)
  es_centro_validacion Boolean?              @default(false)
  direccion            String?
  empleados            empleados[]
  insumos_stock        insumos_stock[]
  movimientos_insumos  movimientos_insumos[]
}

model parroquias {
  id           Int        @id @default(autoincrement())
  codigo       String     @db.Char(50)
  nombre       String     @db.VarChar(100)
  area_km2     Decimal?   @default(0) @db.Decimal(10, 2)
  municipio_id Int
  municipios   municipios @relation(fields: [municipio_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sectores     sectores[]

  @@unique([municipio_id, codigo], map: "uq_parroquia_codigo")
}

model plagas {
  id                Int              @id @default(autoincrement())
  nombre            String           @unique @db.VarChar(100)
  nombre_cientifico String?          @unique @db.VarChar(100)
  descripcion       String?
  tipo_plaga_id     Int?
  t_plagas          t_plagas?        @relation(fields: [tipo_plaga_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_plagas_tipo")
  programa_plaga    programa_plaga[]
}

model planificacion_empleados {
  id               Int             @id @default(autoincrement())
  planificacion_id Int
  empleado_id      Int
  empleados        empleados       @relation(fields: [empleado_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  planificaciones  planificaciones @relation(fields: [planificacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([planificacion_id, empleado_id], map: "uq_planificacion_empleado")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model planificaciones {
  id                      Int                       @id @default(autoincrement())
  codigo                  String?                   @unique @db.VarChar(40)
