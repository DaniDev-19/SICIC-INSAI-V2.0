generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model acta_silos {
  id                       Int                        @id @default(autoincrement())
  semana_epid              String?                    @db.VarChar(100)
  fecha_notificacion       DateTime?                  @default(dbgenerated("CURRENT_DATE")) @db.Date
  lugar_ubicacion          String?                    @db.VarChar(100)
  cant_nacional            Decimal?                   @db.Decimal(14, 2)
  cant_importado           Decimal?                   @db.Decimal(14, 2)
  cant_afectado            Decimal?                   @db.Decimal(14, 2)
  cant_afectado_porcentaje Decimal?                   @db.Decimal(5, 2)
  n_silos                  String?                    @db.VarChar(240)
  n_galpones               String?                    @db.VarChar(240)
  c_instalada              String?                    @db.VarChar(240)
  c_operativa              String?                    @db.VarChar(240)
  c_almacenamiento         String?                    @db.VarChar(240)
  destino_objetivo         String?                    @db.VarChar(240)
  observaciones            String?
  medidas_recomendadas     String?
  evento_id                Int?
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                  @default(now()) @db.Timestamp(6)
  unidad_medida_id         Int?
  planificacion_id         Int?
  planificaciones          planificaciones?           @relation(fields: [planificacion_id], references: [id], onUpdate: NoAction)
  t_unidades               t_unidades?                @relation(fields: [unidad_medida_id], references: [id], onUpdate: NoAction)
  t_evento                 t_evento?                  @relation(fields: [evento_id], references: [id], onUpdate: NoAction, map: "fk_eventos")
  movimientos_insumos      movimientos_insumos[]
  seguimiento_inspecciones seguimiento_inspecciones[]
  silo_fotos               silo_fotos[]
}

model animales {
  id                   Int                  @id @default(autoincrement())
  nombre               String               @unique @db.VarChar(100)
  nombre_cientifico    String?              @unique @db.VarChar(100)
  dieta                String?              @db.VarChar(100)
  esperanza_vida       String?              @db.VarChar(100)
  habitat_principal    String?              @db.VarChar(100)
  peso_promedio_kg     Decimal?             @db.Decimal(10, 2)
  longitud_promedio_mt Decimal?             @db.Decimal(10, 2)
  descripcion          String?
  tipo_animal_id       Int?
  created_at           DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?            @default(now()) @db.Timestamptz(6)
  t_animales           t_animales?          @relation(fields: [tipo_animal_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_tipo_animales")
  programa_animales    programa_animales[]
  propiedad_animales   propiedad_animales[]
}

model aval_biologicos {
  id                   Int               @id @default(autoincrement())
  aval_id              Int
  insumo_id            Int?
  fecha_vacunacion     DateTime?         @db.Date
  pruebas_diagnosticas String?
  created_at           DateTime?         @default(now()) @db.Timestamp(6)
  avales_sanitarios    avales_sanitarios @relation(fields: [aval_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  insumos              insumos?          @relation(fields: [insumo_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model aval_hallazgos_bov_buf {
  id                Int               @id @default(autoincrement())
  aval_id           Int
  t_toros           Int?              @default(0)
  t_vacas           Int?              @default(0)
  t_novillos        Int?              @default(0)
  t_novillas        Int?              @default(0)
  t_mautes_m        Int?              @default(0)
  t_mautes_h        Int?              @default(0)
  t_becerros        Int?              @default(0)
  t_becerras        Int?              @default(0)
  t_bufalos         Int?              @default(0)
  t_bufalas         Int?              @default(0)
  t_buvillos        Int?              @default(0)
  t_buvillas        Int?              @default(0)
  t_bumautes_m      Int?              @default(0)
  t_bumautes_h      Int?              @default(0)
  t_bucerros        Int?              @default(0)
  t_bucerras        Int?              @default(0)
  total_bov_buf     Int?              @default(0)
  created_at        DateTime?         @default(now()) @db.Timestamp(6)
  avales_sanitarios avales_sanitarios @relation(fields: [aval_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model aval_hallazgos_otras {
  id                Int               @id @default(autoincrement())
  aval_id           Int
  tipo_animal_id    Int?
  machos            Int?              @default(0)
  hembras           Int?              @default(0)
  crias             Int?              @default(0)
  total             Int?              @default(0)
  created_at        DateTime?         @default(now()) @db.Timestamp(6)
  avales_sanitarios avales_sanitarios @relation(fields: [aval_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  t_animales        t_animales?       @relation(fields: [tipo_animal_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model aval_hierros {
  id                Int               @id @default(autoincrement())
  aval_id           Int
  hierro_img_url    String
  created_at        DateTime?         @default(now()) @db.Timestamp(6)
  avales_sanitarios avales_sanitarios @relation(fields: [aval_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model avales_sanitarios {
  id                                                           Int                      @id @default(autoincrement())
  numero_aval                                                  String                   @unique @db.VarChar(100)
  codigo_predio                                                String?                  @db.VarChar(100)
  fecha_emision                                                DateTime?                @default(dbgenerated("CURRENT_DATE")) @db.Date
  fecha_vencimiento                                            DateTime?                @db.Date
  certificado_vacunacion_n                                     String?                  @db.VarChar(150)
  observaciones                                                String?
  inspeccion_id                                                Int?
  medico_responsable_id                                        Int?
  jefe_osa_id                                                  Int?
  created_at                                                   DateTime?                @default(now()) @db.Timestamp(6)
  aval_biologicos                                              aval_biologicos[]
  aval_hallazgos_bov_buf                                       aval_hallazgos_bov_buf[]
  aval_hallazgos_otras                                         aval_hallazgos_otras[]
  aval_hierros                                                 aval_hierros[]
  inspecciones                                                 inspecciones?            @relation(fields: [inspeccion_id], references: [id], onUpdate: NoAction)
  empleados_avales_sanitarios_jefe_osa_idToempleados           empleados?               @relation("avales_sanitarios_jefe_osa_idToempleados", fields: [jefe_osa_id], references: [id], onUpdate: NoAction)
  empleados_avales_sanitarios_medico_responsable_idToempleados empleados?               @relation("avales_sanitarios_medico_responsable_idToempleados", fields: [medico_responsable_id], references: [id], onUpdate: NoAction)
  movimientos_insumos                                          movimientos_insumos[]
}

model bitacora {
  id                Int        @id @default(autoincrement())
  fecha             DateTime?  @default(now()) @db.Timestamp(6)
  accion            String     @db.VarChar(100)
  modulo            String     @db.VarChar(100)
  usuario_global_id Int
  empleado_id       Int?
  username_log      String?    @db.VarChar(100)
  payload_previo    Json?
  payload_nuevo     Json?
  empleados         empleados? @relation(fields: [empleado_id], references: [id], onUpdate: NoAction)
}

model c_insumos {
  id      Int       @id @default(autoincrement())
  nombre  String    @unique @db.VarChar(100)
  insumos insumos[]
}

model carac_statal {
  id                             Int        @id @default(autoincrement())
  num_veterinarios_oficiales     Int?       @default(0)
  num_paraveterinarios_oficiales Int?       @default(0)
  num_administrativos_oficiales  Int?       @default(0)
  num_vehiculos_operativos       Int?       @default(0)
  fecha_actualizacion            DateTime?  @default(now()) @db.Timestamp(6)
  municipio_id                   Int        @unique(map: "municipio_recurso")
  municipios                     municipios @relation(fields: [municipio_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model cargos {
  id        Int         @id @default(autoincrement())
  nombre    String      @unique @db.VarChar(100)
  empleados empleados[]
}

model clientes {
  id               Int           @id @default(autoincrement())
  cedula_rif       String        @unique @db.VarChar(20)
  nombre           String        @db.VarChar(255)
  codigo_runsai    String?       @db.VarChar(50)
  telefono         String?       @db.VarChar(50)
  email            String?       @db.VarChar(100)
  direccion_fiscal String?
  created_at       DateTime?     @default(now()) @db.Timestamp(6)
  propiedades      propiedades[]
  solicitudes      solicitudes[]
}

model contrato {
  id        Int         @id @default(autoincrement())
  nombre    String      @unique @db.VarChar(100)
  empleados empleados[]
}

model cultivo {
  id                Int                 @id @default(autoincrement())
  nombre            String              @unique @db.VarChar(100)
  nombre_cientifico String?             @unique @db.VarChar(100)
  descripcion       String?
  tipo_cultivo_id   Int?
  t_cultivo         t_cultivo?          @relation(fields: [tipo_cultivo_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_tipo_cultivo")
  programa_cultivo  programa_cultivo[]
  propiedad_cultivo propiedad_cultivo[]
}

model departamentos {
  id        Int         @id @default(autoincrement())
  nombre    String      @unique @db.VarChar(100)
  empleados empleados[]
}

model empleado_foto {
  id          Int       @id @default(autoincrement())
  foto_url    String
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  empleado_id Int
  empleados   empleados @relation(fields: [empleado_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_foto_empleado")
}

model empleado_residencia {
  id                  Int       @id @default(autoincrement())
  empleado_id         Int
  sector_id           Int?
  direccion_detallada String?
  punto_referencia    String?
  google_maps_url     String?
  es_principal        Boolean?  @default(true)
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  empleados           empleados @relation(fields: [empleado_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sectores            sectores? @relation(fields: [sector_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
}

model empleados {
  id                                                                   Int                       @id @default(autoincrement())
  cedula                                                               String                    @unique @db.VarChar(20)
  nombre                                                               String                    @db.VarChar(100)
  apellido                                                             String                    @db.VarChar(100)
  telefono                                                             String?                   @db.VarChar(50)
  email                                                                String?                   @db.VarChar(100)
  fechas_ingreso                                                       DateTime?                 @db.Date
  status_laboral                                                       String?                   @default("ACTIVO") @db.VarChar(100)
  contrato_id                                                          Int?
  cargo_id                                                             Int?
  departamento_id                                                      Int?
  profesion_id                                                         Int?
  oficina_id                                                           Int?
  usuario_global_id                                                    Int?
  created_at                                                           DateTime?                 @default(now()) @db.Timestamp(6)
  avales_sanitarios_avales_sanitarios_jefe_osa_idToempleados           avales_sanitarios[]       @relation("avales_sanitarios_jefe_osa_idToempleados")
  avales_sanitarios_avales_sanitarios_medico_responsable_idToempleados avales_sanitarios[]       @relation("avales_sanitarios_medico_responsable_idToempleados")
  bitacora                                                             bitacora[]
  empleado_foto                                                        empleado_foto[]
  empleado_residencia                                                  empleado_residencia[]
  cargos                                                               cargos?                   @relation(fields: [cargo_id], references: [id], onUpdate: NoAction)
  contrato                                                             contrato?                 @relation(fields: [contrato_id], references: [id], onUpdate: NoAction)
  departamentos                                                        departamentos?            @relation(fields: [departamento_id], references: [id], onUpdate: NoAction)
  oficinas                                                             oficinas?                 @relation(fields: [oficina_id], references: [id], onUpdate: NoAction)
  profesiones                                                          profesiones?              @relation(fields: [profesion_id], references: [id], onUpdate: NoAction)
  empleados_programas                                                  empleados_programas[]
  movimientos_insumos                                                  movimientos_insumos[]
  planificacion_empleados                                              planificacion_empleados[]
  solicitudes                                                          solicitudes[]
}

model empleados_programas {
  id          Int       @id @default(autoincrement())
  programa_id Int
  empleado_id Int
  empleados   empleados @relation(fields: [empleado_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ep_empleado")
  programas   programas @relation(fields: [programa_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ep_programa")

  @@unique([programa_id, empleado_id], map: "uq_empleado_programa")
}

model enfermedades {
  id                      Int                       @id @default(autoincrement())
  nombre                  String                    @unique @db.VarChar(100)
  nombre_cientifico       String?                   @unique @db.VarChar(100)
  zoonatica               String?                   @db.VarChar(100)
  descripcion             String?
  tipo_enfermedad_id      Int?
  t_enfermedades          t_enfermedades?           @relation(fields: [tipo_enfermedad_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_enfermedad_tipo")
  epidemiologia_hallazgos epidemiologia_hallazgos[]
  programa_enfermedades   programa_enfermedades[]
}

model epidemiologia_hallazgos {
  id             Int           @id @default(autoincrement())
  inspeccion_id  Int
  enfermedad_id  Int?
  c_probados     Int?          @default(0)
  c_positivos    Int?          @default(0)
  c_reactores    Int?          @default(0)
  c_marcados     Int?          @default(0)
  c_sacrificados Int?          @default(0)
  o_tecnicas     String?
  created_at     DateTime?     @default(now()) @db.Timestamp(6)
  enfermedades   enfermedades? @relation(fields: [enfermedad_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  inspecciones   inspecciones  @relation(fields: [inspeccion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model estados {
  id         Int          @id @default(autoincrement())
  codigo     String       @unique @db.Char(50)
  area_km2   Decimal?     @default(0) @db.Decimal(10, 2)
  nombre     String       @unique @db.VarChar(100)
  municipios municipios[]
}

model finalidad {
  id                   Int                    @id @default(autoincrement())
  nombre               String                 @unique
  finalidad_inspeccion finalidad_inspeccion[]
}

model finalidad_inspeccion {
  id            Int          @id @default(autoincrement())
  inspeccion_id Int
  finalidad_id  Int
  objetivo      String?
  finalidad     finalidad    @relation(fields: [finalidad_id], references: [id], onUpdate: NoAction)
  inspecciones  inspecciones @relation(fields: [inspeccion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([inspeccion_id, finalidad_id], map: "uq_inspeccion_finalidad")
}

model inspeccion_fotos {
  id            Int          @id @default(autoincrement())
  imagen        String
  inspeccion_id Int
  created_at    DateTime?    @default(now()) @db.Timestamp(6)
  inspecciones  inspecciones @relation(fields: [inspeccion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model inspecciones {
  id                       Int                        @id @default(autoincrement())
  n_control                String                     @db.VarChar(100)
  t_codigo                 String?                    @default("10-00-M00-P00-F01") @db.VarChar(100)
  fecha_inspeccion         DateTime                   @default(dbgenerated("CURRENT_DATE")) @db.Date
  hora_inspeccion          DateTime?                  @db.Time(6)
  atendido_por_nombre      String?                    @db.VarChar(150)
  atendido_por_cedula      String?                    @db.VarChar(20)
  atendido_por_email       String?                    @db.VarChar(100)
  atendido_por_tlf         String?                    @db.VarChar(50)
  insp_utm_norte           Decimal?                   @db.Decimal
  insp_utm_este            Decimal?                   @db.Decimal
  insp_utm_zona            String?                    @db.VarChar(100)
  google_maps_url          String?
  aspectos_constatados     String?
  medidas_ordenadas        String?
  posee_certificado        String?                    @db.VarChar(100)
  vigencia_dias            Int?                       @default(30)
  status                   String?                    @default("PENDIENTE") @db.VarChar(100)
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                  @default(now()) @db.Timestamp(6)
  planificacion_id         Int?
  avales_sanitarios        avales_sanitarios[]
  epidemiologia_hallazgos  epidemiologia_hallazgos[]
  finalidad_inspeccion     finalidad_inspeccion[]
  inspeccion_fotos         inspeccion_fotos[]
  planificaciones          planificaciones?           @relation(fields: [planificacion_id], references: [id], onUpdate: NoAction)
  movimientos_insumos      movimientos_insumos[]
  seguimiento_inspecciones seguimiento_inspecciones[]
}

model insumos {
  id                  Int                   @id @default(autoincrement())
  codigo              String?               @unique @db.VarChar(100)
  nombre              String                @db.VarChar(150)
  marca               String?               @db.VarChar(100)
  descripcion         String?
  categoria_id        Int?
  unidad_medida_id    Int?
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  aval_biologicos     aval_biologicos[]
  c_insumos           c_insumos?            @relation(fields: [categoria_id], references: [id], onUpdate: NoAction)
  t_unidades          t_unidades?           @relation(fields: [unidad_medida_id], references: [id], onUpdate: NoAction)
  insumos_stock       insumos_stock[]
  movimientos_insumos movimientos_insumos[]
}

model insumos_stock {
  id                Int       @id @default(autoincrement())
  insumo_id         Int
  oficina_id        Int
  lote              String?   @db.VarChar(100)
  fecha_vencimiento DateTime? @db.Date
  stock_actual      Decimal?  @default(0) @db.Decimal(12, 2)
  stock_minimo      Decimal?  @default(0) @db.Decimal(12, 2)
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  updated_at        DateTime? @default(now()) @db.Timestamp(6)
  insumos           insumos   @relation(fields: [insumo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  oficinas          oficinas  @relation(fields: [oficina_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([insumo_id, oficina_id, lote], map: "uq_insumo_oficina_lote")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
