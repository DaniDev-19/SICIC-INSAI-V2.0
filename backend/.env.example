# Credenciales de Base de Datos para URLs dinámicas
DB_USER="postgres"
DB_PASSWORD="123456"
DB_HOST="localhost"
DB_PORT="5432"

# url base de datos master
MASTER_DATABASE_URL="postgresql://postgres:contraseña@localhost:puerto/nombre_basededatos?schema=public"

# puerto de salida del servidor
PORT=4000

# clave secreta jwt
JWT_SECRET="clave secreta"

# modo development o production
NODE_ENV=development

# Cors
ALLOWED_ORIGINS="http://localhost:5173"

# modo local o r2
STORAGE_MODE=local

# credenciales de almacenamiento en la nube de imagenes cloudflare
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://your_public_domain_or_r2_url

# url para el almacenamiento localde imagenes
UPLOAD_URL_BASE=http://localhost:4000/uploads
